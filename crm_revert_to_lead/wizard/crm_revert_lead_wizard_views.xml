<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_revert_lead_wizard_form" model="ir.ui.view">
        <field name="name">crm.revert.lead.wizard.form</field>
        <field name="model">crm.revert.lead.wizard</field>
        <field name="arch" type="xml">
            <form string="Revert to Lead">
                <sheet>
                    <p>Are you sure you want to revert the selected opportunity(ies) back to lead(s)?</p>
                    <p>Changing the type back to Lead will preserve all notes, activities, and messages, but the records will be moved out of the pipeline and back to the Leads list.</p>
                    <field name="lead_id" invisible="1"/>
                </sheet>
                <footer>
                    <button name="action_confirm_revert" string="Confirm" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open the wizard from the "Action" menu -->
    <record id="action_crm_revert_lead_bulk" model="ir.actions.act_window">
        <field name="name">Revert to Lead</field>
        <field name="res_model">crm.revert.lead.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="crm.model_crm_lead"/>
        <field name="binding_view_types">list</field>
    </record>
</odoo>
