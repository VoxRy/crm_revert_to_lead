<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit the Lead Form View to add the button -->
    <record id="crm_lead_view_form_revert_to_lead" model="ir.ui.view">
        <field name="name">crm.lead.form.revert.to.lead</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <!-- Add the button in the header -->
            <xpath expr="//header" position="inside">
                <field name="stage_sequence" invisible="1"/>
                <button name="action_revert_to_lead" 
                        string="Revert to Lead" 
                        type="object" 
                        class="btn-secondary"
                        attrs="{'invisible': [('type', '!=', 'opportunity')]}"
                        groups="sales_team.group_sale_salesman"/>
            </xpath>
        </field>
    </record>
</odoo>
